# Bind to the internal network interface that server-kpi can reach.
ONEC_BRIDGE_HOST=0.0.0.0
ONEC_BRIDGE_PORT=12110

# Generate a long random value and set the same value in server-kpi.
ONEC_BRIDGE_TOKEN=change-me

# Connection details are passed to PowerShell through environment variables.
# Never commit the real password.
ONEC_SERVER=kufib
ONEC_DATABASE=copy10062025

# Recommended: encrypted Windows credential file created with:
# Get-Credential | Export-Clixml C:\NNMC\onec-bridge\onec-credential.xml
ONEC_CREDENTIAL_PATH=C:\NNMC\onec-bridge\onec-credential.xml

# Plain environment credentials are supported only as a fallback.
# ONEC_USER=integration-user
# ONEC_PASSWORD=change-me

# Optional limits.
ONEC_BRIDGE_TIMEOUT_MS=120000
ONEC_BRIDGE_LIST_LIMIT=500
ONEC_BRIDGE_DAILY_LIST_LIMIT=10000

# Persistent local cache and automatic refresh time in Windows local time.
ONEC_BRIDGE_DATA_DIR=C:\NNMC\onec-bridge\data
ONEC_BRIDGE_DAILY_SYNC_HOUR=7
