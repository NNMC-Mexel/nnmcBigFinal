<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- LAN-only backends (office Wi-Fi) are served over plain HTTP.
         Cleartext is permitted ONLY for the internal server host. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.101.25</domain>
    </domain-config>
</network-security-config>
