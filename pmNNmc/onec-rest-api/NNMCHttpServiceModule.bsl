Функция НайтиВидОтпускаОтпуск(ОтпускДанные)
	Идентификатор = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "typeId", "")));
	Если Не ПустаяСтрока(Идентификатор) Тогда
		Попытка
			ЗапросПоИдентификатору = Новый Запрос;
			ЗапросПоИдентификатору.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ВидыОтпусков.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.ВидыОтпусков КАК ВидыОтпусков
			|ГДЕ
			|	НЕ ВидыОтпусков.ПометкаУдаления
			|	И НЕ ВидыОтпусков.Недействителен
			|	И ВидыОтпусков.АУ_ИдентификаторSimbase = &Идентификатор";
			ЗапросПоИдентификатору.УстановитьПараметр("Идентификатор", Идентификатор);
			ВыборкаПоИдентификатору = ЗапросПоИдентификатору.Выполнить().Выбрать();
			Если ВыборкаПоИдентификатору.Следующий() Тогда
				Возврат ВыборкаПоИдентификатору.Ссылка;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Наименование = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "type", "")));
	ВидОтпуска = НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, Истина);
	Если ЗначениеЗаполнено(ВидОтпуска) Тогда
		Возврат ВидОтпуска;
	КонецЕсли;

	НижнееНаименование = НРег(Наименование);
	Варианты = Новый Массив;
	Если СтрНайти(НижнееНаименование, "ежегод") > 0 Или СтрНайти(НижнееНаименование, "оплач") > 0 Тогда
		Варианты.Добавить("Отпуск ежегодный");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "без сохран") > 0 Или СтрНайти(НижнееНаименование, "без оплат") > 0 Тогда
		Варианты.Добавить("отпуск без сохранения заработной платы");
		Варианты.Добавить("Отпуск без оплаты");
		Варианты.Добавить("Отпуск без сохранения оплаты");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "учеб") > 0 Тогда
		Варианты.Добавить("Дополнительный учебный отпуск (оплачиваемый)");
		Варианты.Добавить("Дополнительный учебный отпуск без оплаты");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "беремен") > 0 Или СтрНайти(НижнееНаименование, "род") > 0 Тогда
		Варианты.Добавить("отпуск по беременности и родам");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "уход") > 0 И СтрНайти(НижнееНаименование, "реб") > 0 Тогда
		Варианты.Добавить("Отпуск по уходу за ребенком");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "скрининг") > 0 Тогда
		Варианты.Добавить("Отпуск для прохождения скрининговых исследований");
	КонецЕсли;

	Для каждого Вариант Из Варианты Цикл
		ВидОтпуска = НайтиВидОтпускаПоНаименованиюОтпуск(Вариант, Истина);
		Если ЗначениеЗаполнено(ВидОтпуска) Тогда
			Возврат ВидОтпуска;
		КонецЕсли;
	КонецЦикла;

	Возврат НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, Ложь);
КонецФункции

Функция НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, ТочноеСовпадение)
	Наименование = СокрЛП(Строка(Наименование));
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросВидаОтпуска = Новый Запрос;
	Если ТочноеСовпадение Тогда
		УсловиеНаименования = "ВРЕГ(ВидыОтпусков.Наименование) = ВРЕГ(&Наименование)";
		ПараметрНаименования = Наименование;
	Иначе
		УсловиеНаименования = "ВРЕГ(ВидыОтпусков.Наименование) ПОДОБНО ВРЕГ(&Наименование)";
		ПараметрНаименования = "%" + Наименование + "%";
	КонецЕсли;
	ЗапросВидаОтпуска.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыОтпусков.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыОтпусков КАК ВидыОтпусков
	|ГДЕ
	|	НЕ ВидыОтпусков.ПометкаУдаления
	|	И НЕ ВидыОтпусков.Недействителен
	|	И " + УсловиеНаименования;
	ЗапросВидаОтпуска.УстановитьПараметр("Наименование", ПараметрНаименования);
	ВыборкаВидаОтпуска = ЗапросВидаОтпуска.Выполнить().Выбрать();
	Если ВыборкаВидаОтпуска.Следующий() Тогда
		Возврат ВыборкаВидаОтпуска.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция КомментарийОтпускаBPM(Маркер, Данные, СотрудникДанные, ОтпускДанные, РуководительДанные)
	Комментарий = Маркер;
	Комментарий = Комментарий + Символы.ПС + "Источник: " + СокрЛП(Строка(ПолеJSON(Данные, "source", "NNMC BPM")));
	Комментарий = Комментарий + Символы.ПС + "Сотрудник: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "fio", "")));
	Комментарий = Комментарий + Символы.ПС + "ИИН: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "iin", "")));
	Комментарий = Комментарий + Символы.ПС + "Табельный номер: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "personnelNumber", "")));
	Комментарий = Комментарий + Символы.ПС + "Подразделение: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "department", "")));
	Комментарий = Комментарий + Символы.ПС + "Должность: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "position", "")));
	Комментарий = Комментарий + Символы.ПС + "Вид отпуска: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "type", "")));
	Комментарий = Комментарий + Символы.ПС + "Период: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "startDate", "")))
		+ " - " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "endDate", "")));
	Комментарий = Комментарий + Символы.ПС + "Дней: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "calendarDays", "")));
	Комментарий = Комментарий + Символы.ПС + "Замещающий: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "replacementEmployeeName", "")));
	Если ТипЗнч(РуководительДанные) = Тип("Структура") Тогда
		Комментарий = Комментарий + Символы.ПС + "Руководитель: " + СокрЛП(Строка(ПолеJSON(РуководительДанные, "name", "")));
	КонецЕсли;
	КомментарийПользователя = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "comment", "")));
	Если Не ПустаяСтрока(КомментарийПользователя) Тогда
		Комментарий = Комментарий + Символы.ПС + "Комментарий: " + КомментарийПользователя;
	КонецЕсли;
	Возврат Комментарий;
КонецФункции
