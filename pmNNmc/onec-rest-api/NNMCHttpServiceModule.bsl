Функция EmployeesGET(Запрос)
	Попытка
		Подразделение = ПараметрЗапроса(Запрос, "department");
		Если ПустаяСтрока(Подразделение) Тогда
			Возврат ОтветСОшибкой(400, "department_required", "Параметр department обязателен");
		КонецЕсли;

		ТекущаяДатаСеанса = ТекущаяДата();
		ГодПериода = ЦелыйПараметр(Запрос, "year", Год(ТекущаяДатаСеанса), 2000, 2100);
		МесяцПериода = ЦелыйПараметр(Запрос, "month", Месяц(ТекущаяДатаСеанса), 1, 12);
		Лимит = ЦелыйПараметр(Запрос, "limit", 1000, 1, 5000);

		ДатаНачала = Дата(ГодПериода, МесяцПериода, 1);
		ДатаОкончания = ДобавитьМесяц(ДатаНачала, 1);

		ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ %Лимит%
		|	Данные.Сотрудник КАК Сотрудник,
		|	ПРЕДСТАВЛЕНИЕ(Данные.Сотрудник) КАК ФИО,
		|	Данные.Ссылка.Подразделение КАК Подразделение,
		|	ПРЕДСТАВЛЕНИЕ(Данные.Ссылка.Подразделение) КАК НаименованиеПодразделения,
		|	Данные.Должность КАК Должность,
		|	ПРЕДСТАВЛЕНИЕ(Данные.Должность) КАК НаименованиеДолжности,
		|	Данные.КатегорияДолжности КАК Категория,
		|	ПРЕДСТАВЛЕНИЕ(Данные.КатегорияДолжности) КАК НаименованиеКатегории,
		|	ПРЕДСТАВЛЕНИЕ(Данные.Ссылка.Организация) КАК Организация
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени.ДанныеОВремени КАК Данные
		|ГДЕ
		|	Данные.Ссылка.Проведен = ИСТИНА
		|	И Данные.Ссылка.ПериодРегистрации >= &ДатаНачала
		|	И Данные.Ссылка.ПериодРегистрации < &ДатаОкончания
		|	И Данные.Ссылка.Подразделение.Наименование = &Подразделение";

		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%Лимит%", Формат(Лимит, "ЧГ=0"));

		ЗапросДанных = Новый Запрос;
		ЗапросДанных.Текст = ТекстЗапроса;
		ЗапросДанных.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросДанных.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросДанных.УстановитьПараметр("Подразделение", Подразделение);

		Сотрудники = Новый Массив;
		Выборка = ЗапросДанных.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Сотрудник = Новый Структура;
			Сотрудник.Вставить("id", UUIDСсылки(Выборка.Сотрудник));
			Сотрудник.Вставить("fio", СокрЛП(Строка(Выборка.ФИО)));
			Сотрудник.Вставить("departmentId", UUIDСсылки(Выборка.Подразделение));
			Сотрудник.Вставить("department", СокрЛП(Строка(Выборка.НаименованиеПодразделения)));
			Сотрудник.Вставить("positionId", UUIDСсылки(Выборка.Должность));
			Сотрудник.Вставить("position", СокрЛП(Строка(Выборка.НаименованиеДолжности)));
			Сотрудник.Вставить("categoryId", UUIDСсылки(Выборка.Категория));
			Сотрудник.Вставить("category", СокрЛП(Строка(Выборка.НаименованиеКатегории)));
			Сотрудник.Вставить("organization", СокрЛП(Строка(Выборка.Организация)));
			Сотрудник.Вставить("active", Истина);
			Сотрудники.Добавить(Сотрудник);
		КонецЦикла;

		Мета = Новый Структура;
		Мета.Вставить("year", ГодПериода);
		Мета.Вставить("month", МесяцПериода);
		Мета.Вставить("department", Подразделение);
		Мета.Вставить("count", Сотрудники.Количество());
		Мета.Вставить("source", "ТабельУчетаРабочегоВремени.ДанныеОВремени");

		Результат = Новый Структура;
		Результат.Вставить("items", Сотрудники);
		Результат.Вставить("meta", Мета);
		Возврат JSONОтвет(200, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция EmployeeCardsGET(Запрос)
	Попытка
		Страница = ЦелыйПараметр(Запрос, "page", 1, 1, 1000000);
		РазмерСтраницы = ЦелыйПараметр(Запрос, "pageSize", 100, 1, 500);
		ОрганизацияОтбор = ПараметрЗапроса(Запрос, "organization");
		ДатаАктуальности = НачалоДня(ТекущаяДата());
		ПустаяДата = Дата(1, 1, 1);

		ТекстЗапроса =
		"ВЫБРАТЬ
		|	КадровыеДанные.ФизическоеЛицо КАК ФизическоеЛицо,
		|	КадровыеДанные.Сотрудник КАК Сотрудник,
		|	КадровыеДанные.ТекущаяОрганизация КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ТекущаяОрганизация) КАК НаименованиеОрганизации,
		|	КадровыеДанные.ТекущееПодразделение КАК Подразделение,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ТекущееПодразделение) КАК НаименованиеПодразделения,
		|	КадровыеДанные.ТекущаяДолжность КАК Должность,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ТекущаяДолжность) КАК НаименованиеДолжности,
		|	КадровыеДанные.ТекущийВидЗанятости КАК ВидЗанятости,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ТекущийВидЗанятости) КАК НаименованиеВидаЗанятости,
		|	КадровыеДанные.ОсновноеРабочееМестоВОрганизации КАК ОсновноеРабочееМестоВОрганизации,
		|	КадровыеДанные.КоличествоСтавок КАК КоличествоСтавок,
		|	КадровыеДанные.ДатаПриема КАК ДатаПриема,
		|	КадровыеДанные.ДатаУвольнения КАК ДатаУвольнения,
		|	КадровыеДанные.Сотрудник.Код КАК ТабельныйНомер,
		|	КадровыеДанные.Сотрудник.ИИН КАК ИИНСотрудника,
		|	КадровыеДанные.Сотрудник.ВАрхиве КАК ВАрхиве,
		|	КадровыеДанные.Сотрудник.Уволен КАК Уволен,
		|	КадровыеДанные.ФизическоеЛицо.ИИН КАК ИИНФизическогоЛица,
		|	КадровыеДанные.ФизическоеЛицо.ФИО КАК ФИО,
		|	КадровыеДанные.ФизическоеЛицо.Фамилия КАК Фамилия,
		|	КадровыеДанные.ФизическоеЛицо.Имя КАК Имя,
		|	КадровыеДанные.ФизическоеЛицо.Отчество КАК Отчество,
		|	КадровыеДанные.ФизическоеЛицо.ДатаРождения КАК ДатаРождения,
		|	КадровыеДанные.ФизическоеЛицо.Пол КАК Пол,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ФизическоеЛицо.Пол) КАК НаименованиеПола,
		|	КадровыеДанные.ФизическоеЛицо.Национальность КАК Национальность,
		|	ПРЕДСТАВЛЕНИЕ(КадровыеДанные.ФизическоеЛицо.Национальность) КАК НаименованиеНациональности,
		|	ЕСТЬNULL(Тарифы.ТекущаяТарифнаяСтавка, 0) КАК ТекущаяТарифнаяСтавка,
		|	ЕСТЬNULL(Тарифы.ТекущийФОТ, 0) КАК ТекущийФОТ
		|ИЗ
		|	РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК КадровыеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекущаяТарифнаяСтавкаСотрудников КАК Тарифы
		|		ПО КадровыеДанные.ФизическоеЛицо = Тарифы.ФизическоеЛицо
		|			И КадровыеДанные.Сотрудник = Тарифы.Сотрудник
		|			И КадровыеДанные.ГоловнаяОрганизация = Тарифы.ГоловнаяОрганизация
		|			И КадровыеДанные.ТекущаяОрганизация = Тарифы.ТекущаяОрганизация
		|ГДЕ
		|	НЕ КадровыеДанные.Сотрудник.ПометкаУдаления";

		Если Не ПустаяСтрока(ОрганизацияОтбор) Тогда
			ТекстЗапроса = ТекстЗапроса
				+ Символы.ПС
				+ "И КадровыеДанные.ТекущаяОрганизация.Наименование = &Организация";
		КонецЕсли;

		ТекстЗапроса = ТекстЗапроса
			+ Символы.ПС
			+ "УПОРЯДОЧИТЬ ПО
			|	ИИНФизическогоЛица,
			|	ИИНСотрудника,
			|	ТабельныйНомер";

		ЗапросДанных = Новый Запрос(ТекстЗапроса);
		Если Не ПустаяСтрока(ОрганизацияОтбор) Тогда
			ЗапросДанных.УстановитьПараметр("Организация", ОрганизацияОтбор);
		КонецЕсли;

		КарточкиПоИИН = Новый Соответствие;
		ВсеКарточки = Новый Массив;
		Проблемы = Новый Массив;
		КоличествоМестРаботы = 0;
		Выборка = ЗапросДанных.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Если Выборка.ВАрхиве Или Выборка.Уволен Тогда
				Продолжить;
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ДатаПриема)
				И Выборка.ДатаПриема > ДатаАктуальности Тогда
				Продолжить;
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ДатаУвольнения)
				И Выборка.ДатаУвольнения <> ПустаяДата
				И Выборка.ДатаУвольнения <= ДатаАктуальности Тогда
				Продолжить;
			КонецЕсли;

			ИИН = СокрЛП(Строка(Выборка.ИИНФизическогоЛица));
			Если ПустаяСтрока(ИИН) Тогда
				ИИН = СокрЛП(Строка(Выборка.ИИНСотрудника));
			КонецЕсли;

			Если Не КорректныйИИН(ИИН) Тогда
				Проблема = Новый Структура;
				Проблема.Вставить("code", "invalid_iin");
				Проблема.Вставить("message", "У действующего сотрудника отсутствует корректный ИИН");
				Проблема.Вставить("employeeId", UUIDСсылки(Выборка.Сотрудник));
				Проблема.Вставить("personnelNumber", СокрЛП(Строка(Выборка.ТабельныйНомер)));
				Проблема.Вставить("fio", СокрЛП(Строка(Выборка.ФИО)));
				Проблемы.Добавить(Проблема);
				Продолжить;
			КонецЕсли;

			ИдентификаторФизическогоЛица = UUIDСсылки(Выборка.ФизическоеЛицо);
			Карточка = КарточкиПоИИН.Получить(ИИН);
			Если Карточка = Неопределено Тогда
				Карточка = Новый Структура;
				Карточка.Вставить("physicalPersonId", ИдентификаторФизическогоЛица);
				Карточка.Вставить("iin", ИИН);
				Карточка.Вставить("fio", СокрЛП(Строка(Выборка.ФИО)));
				Карточка.Вставить("lastName", СокрЛП(Строка(Выборка.Фамилия)));
				Карточка.Вставить("firstName", СокрЛП(Строка(Выборка.Имя)));
				Карточка.Вставить("middleName", СокрЛП(Строка(Выборка.Отчество)));
				Карточка.Вставить("birthDate", ДатаИлиНеопределено(Выборка.ДатаРождения));
				Карточка.Вставить("gender", СокрЛП(Строка(Выборка.НаименованиеПола)));
				Карточка.Вставить("nationality", СокрЛП(Строка(Выборка.НаименованиеНациональности)));
				Карточка.Вставить("active", Истина);
				Карточка.Вставить("workplaces", Новый Массив);
				КарточкиПоИИН.Вставить(ИИН, Карточка);
				ВсеКарточки.Добавить(Карточка);
			ИначеЕсли Карточка.physicalPersonId <> ИдентификаторФизическогоЛица Тогда
				Проблема = Новый Структура;
				Проблема.Вставить("code", "duplicate_iin");
				Проблема.Вставить("message", "Один ИИН указан у нескольких физических лиц");
				Проблема.Вставить("employeeId", UUIDСсылки(Выборка.Сотрудник));
				Проблема.Вставить("personnelNumber", СокрЛП(Строка(Выборка.ТабельныйНомер)));
				Проблема.Вставить("fio", СокрЛП(Строка(Выборка.ФИО)));
				Проблемы.Добавить(Проблема);
				Продолжить;
			КонецЕсли;

			ОсновноеМестоРаботы = Выборка.ОсновноеРабочееМестоВОрганизации
				Или ЭтоОсновноеМестоРаботы(Выборка.ВидЗанятости);
			МестоРаботы = Новый Структура;
			МестоРаботы.Вставить("employeeId", UUIDСсылки(Выборка.Сотрудник));
			МестоРаботы.Вставить("personnelNumber", СокрЛП(Строка(Выборка.ТабельныйНомер)));
			МестоРаботы.Вставить("primary", ОсновноеМестоРаботы);
			МестоРаботы.Вставить("organizationId", UUIDСсылки(Выборка.Организация));
			МестоРаботы.Вставить("organization", СокрЛП(Строка(Выборка.НаименованиеОрганизации)));
			МестоРаботы.Вставить("departmentId", UUIDСсылки(Выборка.Подразделение));
			МестоРаботы.Вставить("department", СокрЛП(Строка(Выборка.НаименованиеПодразделения)));
			МестоРаботы.Вставить("positionId", UUIDСсылки(Выборка.Должность));
			МестоРаботы.Вставить("position", СокрЛП(Строка(Выборка.НаименованиеДолжности)));
			МестоРаботы.Вставить("employmentType", СокрЛП(Строка(Выборка.НаименованиеВидаЗанятости)));
			МестоРаботы.Вставить("rate", Выборка.КоличествоСтавок);
			МестоРаботы.Вставить("salary", Выборка.ТекущаяТарифнаяСтавка);
			МестоРаботы.Вставить("payroll", Выборка.ТекущийФОТ);
			МестоРаботы.Вставить("hireDate", ДатаИлиНеопределено(Выборка.ДатаПриема));
			МестоРаботы.Вставить("dismissalDate", ДатаИлиНеопределено(Выборка.ДатаУвольнения));

			Если ОсновноеМестоРаботы Тогда
				Карточка.workplaces.Вставить(0, МестоРаботы);
			Иначе
				Карточка.workplaces.Добавить(МестоРаботы);
			КонецЕсли;
			КоличествоМестРаботы = КоличествоМестРаботы + 1;
		КонецЦикла;

		ВсегоКарточек = ВсеКарточки.Количество();
		НачальныйИндекс = (Страница - 1) * РазмерСтраницы;
		КонечныйИндекс = Мин(НачальныйИндекс + РазмерСтраницы, ВсегоКарточек);
		КарточкиСтраницы = Новый Массив;
		Если НачальныйИндекс < ВсегоКарточек Тогда
			Для Индекс = НачальныйИндекс По КонечныйИндекс - 1 Цикл
				КарточкиСтраницы.Добавить(ВсеКарточки[Индекс]);
			КонецЦикла;
		КонецЕсли;

		КоличествоСтраниц = 0;
		Если ВсегоКарточек > 0 Тогда
			КоличествоСтраниц = Цел((ВсегоКарточек + РазмерСтраницы - 1) / РазмерСтраницы);
		КонецЕсли;

		Мета = Новый Структура;
		Мета.Вставить("page", Страница);
		Мета.Вставить("pageSize", РазмерСтраницы);
		Мета.Вставить("count", КарточкиСтраницы.Количество());
		Мета.Вставить("total", ВсегоКарточек);
		Мета.Вставить("totalPages", КоличествоСтраниц);
		Мета.Вставить("workplaceCount", КоличествоМестРаботы);
		Мета.Вставить("issueCount", Проблемы.Количество());
		Мета.Вставить("organization", ОрганизацияОтбор);
		Мета.Вставить("actualAt", ТекущаяДата());
		Мета.Вставить("source", "1c-current-employee-registers");

		Результат = Новый Структура;
		Результат.Вставить("items", КарточкиСтраницы);
		Результат.Вставить("issues", Проблемы);
		Результат.Вставить("meta", Мета);
		Возврат JSONОтвет(200, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция ПараметрЗапроса(Запрос, ИмяПараметра, ЗначениеПоУмолчанию = "")
	ЗначениеПараметра = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
	Если ЗначениеПараметра = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Возврат СокрЛП(Строка(ЗначениеПараметра));
КонецФункции

Функция ЦелыйПараметр(Запрос, ИмяПараметра, ЗначениеПоУмолчанию, Минимум, Максимум)
	СтроковоеЗначение = ПараметрЗапроса(Запрос, ИмяПараметра);
	Если ПустаяСтрока(СтроковоеЗначение) Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Попытка
		Результат = Цел(Число(СтроковоеЗначение));
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;

	Возврат Макс(Минимум, Мин(Максимум, Результат));
КонецФункции

Функция КорректныйИИН(ИИН)
	Если СтрДлина(ИИН) <> 12 Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Индекс = 1 По 12 Цикл
		Если СтрНайти("0123456789", Сред(ИИН, Индекс, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция ДатаИлиНеопределено(ЗначениеДаты)
	Если Не ЗначениеЗаполнено(ЗначениеДаты) Или ЗначениеДаты = Дата(1, 1, 1) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат ЗначениеДаты;
КонецФункции

Функция ЭтоОсновноеМестоРаботы(ВидЗанятости)
	Если Не ЗначениеЗаполнено(ВидЗанятости) Тогда
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Если ВидЗанятости = ПредопределенноеЗначение(
			"Перечисление.ВидыЗанятости.ОсновноеМестоРаботы") Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Возврат НРег(СокрЛП(Строка(ВидЗанятости))) = "основное место работы";
КонецФункции

Функция UUIDСсылки(Ссылка)
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		Возврат Строка(Ссылка.УникальныйИдентификатор());
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция ОтветСОшибкой(КодСостояния, КодОшибки, Сообщение)
	Ошибка = Новый Структура;
	Ошибка.Вставить("code", КодОшибки);
	Ошибка.Вставить("message", Сообщение);

	Результат = Новый Структура;
	Результат.Вставить("error", Ошибка);
	Возврат JSONОтвет(КодСостояния, Результат);
КонецФункции

Функция JSONОтвет(КодСостояния, Данные)
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Данные);
	ТелоОтвета = Запись.Закрыть();

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Cache-Control", "no-store");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, КодировкаТекста.UTF8);
	Возврат Ответ;
КонецФункции

Функция TimesheetsGET(Запрос)
	Попытка
		Подразделение = ПараметрЗапроса(Запрос, "department");
		Если ПустаяСтрока(Подразделение) Тогда
			Возврат ОтветСОшибкой(400, "department_required", "Параметр department обязателен");
		КонецЕсли;

		ТекущаяДатаСеанса = ТекущаяДата();
		ГодПериода = ЦелыйПараметр(Запрос, "year", Год(ТекущаяДатаСеанса), 2000, 2100);
		МесяцПериода = ЦелыйПараметр(Запрос, "month", Месяц(ТекущаяДатаСеанса), 1, 12);
		Лимит = ЦелыйПараметр(Запрос, "limit", 500, 1, 2000);
		ДатаНачала = Дата(ГодПериода, МесяцПериода, 1);
		ДатаОкончания = ДобавитьМесяц(ДатаНачала, 1);

		ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ %Лимит%
		|	Табель.Ссылка КАК Ссылка,
		|	Табель.Дата КАК Дата,
		|	Табель.Номер КАК Номер,
		|	Табель.ПериодРегистрации КАК ПериодРегистрации,
		|	ПРЕДСТАВЛЕНИЕ(Табель.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(Табель.Подразделение) КАК Подразделение,
		|	Табель.ДатаНачалаПериода КАК ДатаНачалаПериода,
		|	Табель.ДатаОкончанияПериода КАК ДатаОкончанияПериода,
		|	Табель.Проведен КАК Проведен
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени КАК Табель
		|ГДЕ
		|	Табель.Проведен = ИСТИНА
		|	И Табель.ПериодРегистрации >= &ДатаНачала
		|	И Табель.ПериодРегистрации < &ДатаОкончания
		|	И Табель.Подразделение.Наименование = &Подразделение
		|УПОРЯДОЧИТЬ ПО
		|	Табель.Дата УБЫВ";

		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%Лимит%", Формат(Лимит, "ЧГ=0"));
		ЗапросДанных = Новый Запрос(ТекстЗапроса);
		ЗапросДанных.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросДанных.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросДанных.УстановитьПараметр("Подразделение", Подразделение);

		Табели = Новый Массив;
		Выборка = ЗапросДанных.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Табель = Новый Структура;
			Табель.Вставить("id", UUIDСсылки(Выборка.Ссылка));
			Табель.Вставить("date", Выборка.Дата);
			Табель.Вставить("number", СокрЛП(Строка(Выборка.Номер)));
			Табель.Вставить("period", Выборка.ПериодРегистрации);
			Табель.Вставить("organization", СокрЛП(Строка(Выборка.Организация)));
			Табель.Вставить("department", СокрЛП(Строка(Выборка.Подразделение)));
			Табель.Вставить("dateFrom", Выборка.ДатаНачалаПериода);
			Табель.Вставить("dateTo", Выборка.ДатаОкончанияПериода);
			Табель.Вставить("conducted", Выборка.Проведен);
			Табели.Добавить(Табель);
		КонецЦикла;

		Мета = Новый Структура;
		Мета.Вставить("year", ГодПериода);
		Мета.Вставить("month", МесяцПериода);
		Мета.Вставить("department", Подразделение);
		Мета.Вставить("count", Табели.Количество());
		Мета.Вставить("source", "onec-rest");

		Результат = Новый Структура;
		Результат.Вставить("items", Табели);
		Результат.Вставить("meta", Мета);
		Возврат JSONОтвет(200, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция TimesheetGET(Запрос)
	Попытка
		Идентификатор = ПараметрЗапроса(Запрос, "id");
		Если ПустаяСтрока(Идентификатор) Тогда
			Возврат ОтветСОшибкой(400, "id_required", "Параметр id обязателен");
		КонецЕсли;

		Попытка
			Ссылка = Документы.ТабельУчетаРабочегоВремени.ПолучитьСсылку(Новый УникальныйИдентификатор(Идентификатор));
		Исключение
			Возврат ОтветСОшибкой(400, "invalid_id", "Некорректный идентификатор табеля");
		КонецПопытки;

		ЗапросМета = Новый Запрос;
		ЗапросМета.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Табель.Дата КАК Дата,
		|	Табель.Номер КАК Номер,
		|	Табель.ПериодРегистрации КАК ПериодРегистрации,
		|	ПРЕДСТАВЛЕНИЕ(Табель.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(Табель.Подразделение) КАК Подразделение,
		|	Табель.ДатаНачалаПериода КАК ДатаНачалаПериода,
		|	Табель.ДатаОкончанияПериода КАК ДатаОкончанияПериода,
		|	Табель.Проведен КАК Проведен
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени КАК Табель
		|ГДЕ
		|	Табель.Ссылка = &Ссылка
		|	И Табель.Проведен = ИСТИНА";
		ЗапросМета.УстановитьПараметр("Ссылка", Ссылка);
		ВыборкаМета = ЗапросМета.Выполнить().Выбрать();
		Если Не ВыборкаМета.Следующий() Тогда
			Возврат ОтветСОшибкой(404, "not_found", "Проведенный табель не найден");
		КонецЕсли;

		Табель = Новый Структура;
		Табель.Вставить("id", Идентификатор);
		Табель.Вставить("date", ВыборкаМета.Дата);
		Табель.Вставить("number", СокрЛП(Строка(ВыборкаМета.Номер)));
		Табель.Вставить("period", ВыборкаМета.ПериодРегистрации);
		Табель.Вставить("organization", СокрЛП(Строка(ВыборкаМета.Организация)));
		Табель.Вставить("department", СокрЛП(Строка(ВыборкаМета.Подразделение)));
		Табель.Вставить("dateFrom", ВыборкаМета.ДатаНачалаПериода);
		Табель.Вставить("dateTo", ВыборкаМета.ДатаОкончанияПериода);
		Табель.Вставить("conducted", ВыборкаМета.Проведен);

		Поля = "Данные.НомерСтроки КАК НомерСтроки, "
			+ "ПРЕДСТАВЛЕНИЕ(Данные.Сотрудник) КАК ФИО, "
			+ "ПРЕДСТАВЛЕНИЕ(Данные.Должность) КАК Должность, "
			+ "ПРЕДСТАВЛЕНИЕ(Данные.КатегорияДолжности) КАК Категория";
		Для День = 1 По 31 Цикл
			Поля = Поля + ", Данные.Часов" + Строка(День) + " КАК Часов" + Строка(День);
			Поля = Поля + ", ПРЕДСТАВЛЕНИЕ(Данные.ВидВремени" + Строка(День) + ") КАК ВидВремени" + Строка(День);
		КонецЦикла;

		ЗапросСтрок = Новый Запрос;
		ЗапросСтрок.Текст =
		"ВЫБРАТЬ " + Поля + "
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени.ДанныеОВремени КАК Данные
		|ГДЕ
		|	Данные.Ссылка = &Ссылка
		|	И Данные.Ссылка.Проведен = ИСТИНА
		|УПОРЯДОЧИТЬ ПО
		|	Данные.НомерСтроки";
		ЗапросСтрок.УстановитьПараметр("Ссылка", Ссылка);

		Сотрудники = Новый Соответствие;
		ВыборкаСтрок = ЗапросСтрок.Выполнить().Выбрать();
		Пока ВыборкаСтрок.Следующий() Цикл
			ФИО = СокрЛП(Строка(ВыборкаСтрок.ФИО));
			Если ПустаяСтрока(ФИО) Тогда
				Продолжить;
			КонецЕсли;

			Должность = СокрЛП(Строка(ВыборкаСтрок.Должность));
			Категория = СокрЛП(Строка(ВыборкаСтрок.Категория));
			Ключ = ФИО + Символы.ПС + Должность + Символы.ПС + Категория;
			ДанныеСотрудника = Сотрудники.Получить(Ключ);
			Если ДанныеСотрудника = Неопределено Тогда
				Кандидаты = Новый Соответствие;
				Для День = 1 По 31 Цикл
					Кандидаты.Вставить(Строка(День), Новый Массив);
				КонецЦикла;
				ДанныеСотрудника = Новый Структура("fio,position,category,candidates",
					ФИО, Должность, Категория, Кандидаты);
				Сотрудники.Вставить(Ключ, ДанныеСотрудника);
			КонецЕсли;

			Для День = 1 По 31 Цикл
				Часы = ВыборкаСтрок["Часов" + Строка(День)];
				Если Часы = Неопределено Или Часы = Null Тогда
					Часы = 0;
				КонецЕсли;
				ВидВремени = СокрЛП(Строка(ВыборкаСтрок["ВидВремени" + Строка(День)]));
				Кандидат = Новый Структура("hours,timeType", Часы, ВидВремени);
				ДанныеСотрудника.candidates.Получить(Строка(День)).Добавить(Кандидат);
			КонецЦикла;
		КонецЦикла;

		РезультатСотрудники = Новый Массив;
		Для Каждого Элемент Из Сотрудники Цикл
			ДанныеСотрудника = Элемент.Значение;
			Дни = Новый Массив;
			Для День = 1 По 31 Цикл
				Дни.Добавить(ВыбратьЗначениеДня(ДанныеСотрудника.candidates.Получить(Строка(День))));
			КонецЦикла;
			Сотрудник = Новый Структура;
			Сотрудник.Вставить("fio", ДанныеСотрудника.fio);
			Сотрудник.Вставить("position", ДанныеСотрудника.position);
			Сотрудник.Вставить("category", ДанныеСотрудника.category);
			Сотрудник.Вставить("days", Дни);
			РезультатСотрудники.Добавить(Сотрудник);
		КонецЦикла;

		Результат = Новый Структура;
		Результат.Вставить("timesheet", Табель);
		Результат.Вставить("employees", РезультатСотрудники);
		Возврат JSONОтвет(200, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция ВыбратьЗначениеДня(Кандидаты)
	Для Каждого Кандидат Из Кандидаты Цикл
		Если Не ДополнительныйВидВремени(Кандидат.timeType) И Кандидат.hours > 0 Тогда
			Возврат Кандидат.hours;
		КонецЕсли;
	КонецЦикла;

	Для Каждого Кандидат Из Кандидаты Цикл
		Если Не ПустаяСтрока(Кандидат.timeType)
			И Не ДополнительныйВидВремени(Кандидат.timeType)
			И Не ВыходнойВидВремени(Кандидат.timeType) Тогда
			Возврат Кандидат.timeType;
		КонецЕсли;
	КонецЦикла;

	Возврат "";
КонецФункции

Функция ДополнительныйВидВремени(ВидВремени)
	Значение = НРег(СокрЛП(Строка(ВидВремени)));
	Возврат СтрНайти(Значение, "ночн") > 0
		Или СтрНайти(Значение, "празднич") > 0
		Или СтрНайти(Значение, "мерек") > 0
		Или СтрНайти(Значение, "сверхуроч") > 0
		Или СтрНайти(Значение, "дополнительн") > 0;
КонецФункции

Функция ВыходнойВидВремени(ВидВремени)
	Значение = НРег(СокрЛП(Строка(ВидВремени)));
	Возврат СтрНайти(Значение, "выходн") > 0
		Или СтрНайти(Значение, "демалыс") > 0;
КонецФункции

Функция KpiAccrualPOST(Запрос)
	Попытка
		ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
		Если ПустаяСтрока(ТелоЗапроса) Тогда
			Возврат ОтветСОшибкой(400, "body_required", "Тело запроса обязательно");
		КонецЕсли;

		Попытка
			Чтение = Новый ЧтениеJSON;
			Чтение.УстановитьСтроку(ТелоЗапроса);
			Данные = ПрочитатьJSON(Чтение);
			Чтение.Закрыть();
		Исключение
			Возврат ОтветСОшибкой(400, "invalid_json", "Некорректный JSON");
		КонецПопытки;

		ГодПериода = Цел(ЧислоJSON(ПолеJSON(Данные, "year", 0)));
		МесяцПериода = Цел(ЧислоJSON(ПолеJSON(Данные, "month", 0)));
		ОрганизацияНаименование = СокрЛП(Строка(ПолеJSON(Данные, "organization", "")));
		ПодразделениеНаименование = СокрЛП(Строка(ПолеJSON(Данные, "department", "")));
		НачислениеНаименование = СокрЛП(Строка(ПолеJSON(Данные, "accrual", "KPI")));
		КлючЗапроса = СокрЛП(Строка(ПолеJSON(Данные, "idempotencyKey", "")));
		АвторЗапроса = СокрЛП(Строка(ПолеJSON(Данные, "submittedBy", "")));
		СтрокиСотрудников = ПолеJSON(Данные, "employees", Неопределено);
		ТолькоПроверка = ПолеJSON(Данные, "validateOnly", Ложь);
		Если ТипЗнч(ТолькоПроверка) <> Тип("Булево") Тогда
			ТолькоПроверка = Ложь;
		КонецЕсли;

		Если ГодПериода < 2000 Или ГодПериода > 2100 Тогда
			Возврат ОтветСОшибкой(400, "invalid_year", "Некорректный год");
		КонецЕсли;
		Если МесяцПериода < 1 Или МесяцПериода > 12 Тогда
			Возврат ОтветСОшибкой(400, "invalid_month", "Некорректный месяц");
		КонецЕсли;
		Если ПустаяСтрока(ОрганизацияНаименование) Или ПустаяСтрока(ПодразделениеНаименование) Тогда
			Возврат ОтветСОшибкой(400, "header_required", "Организация и подразделение обязательны");
		КонецЕсли;
		Если ТипЗнч(СтрокиСотрудников) <> Тип("Массив") Или СтрокиСотрудников.Количество() = 0 Тогда
			Возврат ОтветСОшибкой(400, "employees_required", "Список сотрудников обязателен");
		КонецЕсли;

		Маркер = "[PM-KPI] " + КлючЗапроса;
		Если ПустаяСтрока(КлючЗапроса) Тогда
			Маркер = "[PM-KPI] " + Формат(ГодПериода, "ЧГ=0")
				+ "-" + Формат(МесяцПериода, "ЧГ=0")
				+ "|" + ПодразделениеНаименование;
		КонецЕсли;

		Если Не ТолькоПроверка Тогда
			ЗапросДубля = Новый Запрос;
			ЗапросДубля.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Документ.Ссылка КАК Ссылка,
			|	Документ.Номер КАК Номер
			|ИЗ
			|	Документ.РазовоеНачисление КАК Документ
			|ГДЕ
			|	НЕ Документ.ПометкаУдаления
			|	И ВЫРАЗИТЬ(Документ.Комментарий КАК СТРОКА(100)) ПОДОБНО &Комментарий";
			ЗапросДубля.УстановитьПараметр("Комментарий", Маркер + "%");
			ВыборкаДубля = ЗапросДубля.Выполнить().Выбрать();
			Если ВыборкаДубля.Следующий() Тогда
				Возврат ОтветСОшибкой(409, "duplicate",
					"Документ KPI уже создан. Номер: " + СокрЛП(Строка(ВыборкаДубля.Номер)));
			КонецЕсли;
		КонецЕсли;

		ЗапросШапки = Новый Запрос;
		ЗапросШапки.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Табель.Организация КАК Организация,
		|	Табель.Подразделение КАК Подразделение
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени КАК Табель
		|ГДЕ
		|	НЕ Табель.ПометкаУдаления
		|	И Табель.Организация.Наименование = &Организация
		|	И Табель.Подразделение.Наименование = &Подразделение
		|УПОРЯДОЧИТЬ ПО
		|	Табель.Дата УБЫВ";
		ЗапросШапки.УстановитьПараметр("Организация", ОрганизацияНаименование);
		ЗапросШапки.УстановитьПараметр("Подразделение", ПодразделениеНаименование);
		ВыборкаШапки = ЗапросШапки.Выполнить().Выбрать();
		Если Не ВыборкаШапки.Следующий() Тогда
			Возврат ОтветСОшибкой(400, "department_not_found",
				"Не удалось определить организацию и подразделение в 1С");
		КонецЕсли;

		Организация = ВыборкаШапки.Организация;
		Подразделение = ВыборкаШапки.Подразделение;

		Если Не ТолькоПроверка Тогда
			ЗапросШаблона = Новый Запрос;
			ЗапросШаблона.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Документ.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.РазовоеНачисление КАК Документ
			|ГДЕ
			|	НЕ Документ.ПометкаУдаления
			|	И Документ.Начисление.Наименование = &Начисление
			|УПОРЯДОЧИТЬ ПО
			|	Документ.Дата УБЫВ";
			ЗапросШаблона.УстановитьПараметр("Начисление", НачислениеНаименование);
			ВыборкаШаблона = ЗапросШаблона.Выполнить().Выбрать();
			Если Не ВыборкаШаблона.Следующий() Тогда
				Возврат ОтветСОшибкой(400, "accrual_not_found",
					"Не найден существующий документ с начислением " + НачислениеНаименование);
			КонецЕсли;
			ШаблонДокумента = ВыборкаШаблона.Ссылка.ПолучитьОбъект();
		КонецЕсли;

		ПодготовленныеСтроки = Новый Массив;
		РезультатыСверки = Новый Массив;
		КоличествоОшибокСверки = 0;
		ИтогоНачислено = 0;
		МесяцНачисления = Дата(ГодПериода, МесяцПериода, 1);
		СледующийМесяц = ДобавитьМесяц(МесяцНачисления, 1);
		ДатаОкончания = КонецМесяца(МесяцНачисления);

		Для Каждого ВходнаяСтрока Из СтрокиСотрудников Цикл
			ФИО = СокрЛП(Строка(ПолеJSON(ВходнаяСтрока, "fio", "")));
			Сумма = Окр(ЧислоJSON(ПолеJSON(ВходнаяСтрока, "amount", 0)), 0);
			Если ПустаяСтрока(ФИО) Или Сумма <= 0 Тогда
				Продолжить;
			КонецЕсли;

			// Сначала выбираем карточку сотрудника, которая фактически использована
			// в проведенном табеле этого подразделения за расчетный месяц.
			ЗапросСотрудникаТабеля = Новый Запрос;
			ЗапросСотрудникаТабеля.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 2
			|	Данные.Сотрудник КАК Ссылка,
			|	Данные.Сотрудник.ВАрхиве КАК ВАрхиве
			|ИЗ
			|	Документ.ТабельУчетаРабочегоВремени.ДанныеОВремени КАК Данные
			|ГДЕ
			|	Данные.Ссылка.Проведен = ИСТИНА
			|	И Данные.Ссылка.Подразделение = &Подразделение
			|	И Данные.Ссылка.ПериодРегистрации >= &НачалоПериода
			|	И Данные.Ссылка.ПериодРегистрации < &КонецПериода
			|	И Данные.Сотрудник.Наименование = &ФИО";
			ЗапросСотрудникаТабеля.УстановитьПараметр("Подразделение", Подразделение);
			ЗапросСотрудникаТабеля.УстановитьПараметр("НачалоПериода", МесяцНачисления);
			ЗапросСотрудникаТабеля.УстановитьПараметр("КонецПериода", СледующийМесяц);
			ЗапросСотрудникаТабеля.УстановитьПараметр("ФИО", ФИО);
			ТаблицаСотрудников = ЗапросСотрудникаТабеля.Выполнить().Выгрузить();

			СтатусСверки = "";
			СообщениеСверки = "";
			СсылкаСотрудника = Неопределено;
			ВАрхиве = Ложь;

			Если ТаблицаСотрудников.Количество() = 0 Тогда
				// Ищем карточку только для диагностики. Отсутствие сотрудника
				// в текущем проведенном табеле все равно блокирует начисление.
				ЗапросСотрудника = Новый Запрос;
				ЗапросСотрудника.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 2
				|	Сотрудник.Ссылка КАК Ссылка,
				|	Сотрудник.ВАрхиве КАК ВАрхиве
				|ИЗ
				|	Справочник.Сотрудники КАК Сотрудник
				|ГДЕ
				|	НЕ Сотрудник.ПометкаУдаления
				|	И Сотрудник.Наименование = &ФИО";
				ЗапросСотрудника.УстановитьПараметр("ФИО", ФИО);
				КарточкиСправочника = ЗапросСотрудника.Выполнить().Выгрузить();

				Если КарточкиСправочника.Количество() = 0 Тогда
					СтатусСверки = "not_found";
					СообщениеСверки = "Сотрудник не найден в 1С";
				Иначе
					ВсеКарточкиВАрхиве = Истина;
					Для Каждого КарточкаСправочника Из КарточкиСправочника Цикл
						Если Не КарточкаСправочника.ВАрхиве Тогда
							ВсеКарточкиВАрхиве = Ложь;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					Если ВсеКарточкиВАрхиве Тогда
						СтатусСверки = "inactive";
						СообщениеСверки = "Карточка сотрудника находится в архиве 1С";
					Иначе
						СтатусСверки = "not_in_timesheet";
						СообщениеСверки = "Активная карточка есть в 1С, но сотрудника нет в проведенном табеле подразделения за период";
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли ТаблицаСотрудников.Количество() > 1 Тогда
				СтатусСверки = "ambiguous";
				СообщениеСверки = "В табеле 1С найдено несколько карточек сотрудника";
			Иначе
				СсылкаСотрудника = ТаблицаСотрудников[0].Ссылка;
				ВАрхиве = ТаблицаСотрудников[0].ВАрхиве;
				Если ВАрхиве Тогда
					СтатусСверки = "inactive";
					СообщениеСверки = "Карточка сотрудника находится в архиве 1С";
				Иначе
					СтатусСверки = "matched";
					СообщениеСверки = "Сотрудник сопоставлен с активной карточкой 1С";
				КонецЕсли;
			КонецЕсли;

			СтрокаСверки = Новый Структура;
			СтрокаСверки.Вставить("fio", ФИО);
			СтрокаСверки.Вставить("amount", Сумма);
			СтрокаСверки.Вставить("status", СтатусСверки);
			СтрокаСверки.Вставить("matched", СтатусСверки = "matched");
			СтрокаСверки.Вставить("active", СтатусСверки = "matched");
			СтрокаСверки.Вставить("employeeId", UUIDСсылки(СсылкаСотрудника));
			СтрокаСверки.Вставить("message", СообщениеСверки);
			РезультатыСверки.Добавить(СтрокаСверки);

			Если СтатусСверки <> "matched" Тогда
				КоличествоОшибокСверки = КоличествоОшибокСверки + 1;
				Продолжить;
			КонецЕсли;

			ПодготовленнаяСтрока = Новый Структура("Сотрудник,Сумма",
				СсылкаСотрудника, Сумма);
			ПодготовленныеСтроки.Добавить(ПодготовленнаяСтрока);
			ИтогоНачислено = ИтогоНачислено + Сумма;
		КонецЦикла;

		Если ТолькоПроверка Тогда
			РезультатПроверки = Новый Структура;
			РезультатПроверки.Вставить("valid", КоличествоОшибокСверки = 0);
			РезультатПроверки.Вставить("matchedCount", ПодготовленныеСтроки.Количество());
			РезультатПроверки.Вставить("rejectedCount", КоличествоОшибокСверки);
			РезультатПроверки.Вставить("items", РезультатыСверки);
			Возврат JSONОтвет(200, РезультатПроверки);
		КонецЕсли;

		Если ПодготовленныеСтроки.Количество() = 0 Тогда
			Возврат ОтветСОшибкой(400, "empty_result",
				"Ни один сотрудник не прошел сверку с активными карточками 1С");
		КонецЕсли;

		КомментарийДокумента = Маркер;
		Если КоличествоОшибокСверки > 0 Тогда
			КомментарийДокумента = КомментарийДокумента
				+ Символы.ПС + "ВНИМАНИЕ: не включены в начисление ("
				+ Строка(КоличествоОшибокСверки) + "):";
			Для Каждого СтрокаСверки Из РезультатыСверки Цикл
				Если Не СтрокаСверки.matched Тогда
					КомментарийДокумента = КомментарийДокумента
						+ Символы.ПС + СтрокаСверки.fio + " - " + СтрокаСверки.message;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;

		НачатьТранзакцию();
		Попытка
			НовыйДокумент = Документы.РазовоеНачисление.СоздатьДокумент();
			ЗаполнитьЗначенияСвойств(НовыйДокумент, ШаблонДокумента,
				"ПорядокВыплаты,Ответственный,СтатьяФинансирования,СтатьяРасходов,"
				+ "СпособОтраженияЗарплатыВБухучете,РассчитыватьУдержания,"
				+ "УдержатьНалогПриВыплатеЗарплаты,СпособРасчетовСФизическимиЛицами");

			НовыйДокумент.Дата = ТекущаяДата();
			НовыйДокумент.МесяцНачисления = МесяцНачисления;
			НовыйДокумент.Организация = Организация;
			НовыйДокумент.Подразделение = Подразделение;
			НовыйДокумент.Начисление = ШаблонДокумента.Начисление;
			НовыйДокумент.ДатаНачала = МесяцНачисления;
			НовыйДокумент.ДатаОкончания = ДатаОкончания;
			НовыйДокумент.ПланируемаяДатаВыплаты = ДатаОкончания;
			НовыйДокумент.Начислено = ИтогоНачислено;
			НовыйДокумент.Удержано = 0;
			НовыйДокумент.Комментарий = КомментарийДокумента;

			Для Каждого ПодготовленнаяСтрока Из ПодготовленныеСтроки Цикл
				СтрокаНачисления = НовыйДокумент.Начисления.Добавить();
				СтрокаНачисления.Сотрудник = ПодготовленнаяСтрока.Сотрудник;
				СтрокаНачисления.Подразделение = Подразделение;
				СтрокаНачисления.Результат = ПодготовленнаяСтрока.Сумма;
				СтрокаНачисления.ПериодРегистрацииВремени = МесяцНачисления;
				СтрокаНачисления.ДатаНачала = МесяцНачисления;
				СтрокаНачисления.ДатаОкончания = ДатаОкончания;
			КонецЦикла;

			НовыйДокумент.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;

		Результат = Новый Структура;
		Результат.Вставить("success", Истина);
		Результат.Вставить("documentId", UUIDСсылки(НовыйДокумент.Ссылка));
		Результат.Вставить("number", СокрЛП(Строка(НовыйДокумент.Номер)));
		Результат.Вставить("date", НовыйДокумент.Дата);
		Результат.Вставить("posted", Ложь);
		Результат.Вставить("employeeCount", ПодготовленныеСтроки.Количество());
		Результат.Вставить("rejectedCount", КоличествоОшибокСверки);
		Результат.Вставить("items", РезультатыСверки);
		Результат.Вставить("total", ИтогоНачислено);
		Результат.Вставить("submittedBy", АвторЗапроса);
		Возврат JSONОтвет(201, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция ПолеJSON(Объект, ИмяПоля, ЗначениеПоУмолчанию = Неопределено)
	Если ТипЗнч(Объект) = Тип("Структура") Тогда
		Значение = Неопределено;
		Если Объект.Свойство(ИмяПоля, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЧислоJSON(Значение)
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	СтроковоеЗначение = СтрЗаменить(СокрЛП(Строка(Значение)), " ", "");
	СтроковоеЗначение = СтрЗаменить(СтроковоеЗначение, ",", ".");
	Если ПустаяСтрока(СтроковоеЗначение) Тогда
		Возврат 0;
	КонецЕсли;
	Попытка
		Возврат Число(СтроковоеЗначение);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции
