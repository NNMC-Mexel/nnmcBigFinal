Функция VacationRequestPOST(Запрос)
	Попытка
		ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
		Если ПустаяСтрока(ТелоЗапроса) Тогда
			Возврат ОтветСОшибкой(400, "body_required", "Тело запроса обязательно");
		КонецЕсли;

		Попытка
			Чтение = Новый ЧтениеJSON;
			Чтение.УстановитьСтроку(ТелоЗапроса);
			Данные = ПрочитатьJSON(Чтение);
			Чтение.Закрыть();
		Исключение
			Возврат ОтветСОшибкой(400, "invalid_json", "Некорректный JSON");
		КонецПопытки;

		КлючЗапроса = СокрЛП(Строка(ПолеJSON(Данные, "requestNumber", "")));
		Если ПустаяСтрока(КлючЗапроса) Тогда
			Возврат ОтветСОшибкой(400, "request_number_required", "requestNumber обязателен");
		КонецЕсли;

		СотрудникДанные = ПолеJSON(Данные, "employee", Неопределено);
		ОтпускДанные = ПолеJSON(Данные, "vacation", Неопределено);
		РуководительДанные = ПолеJSON(Данные, "manager", Неопределено);

		Если ТипЗнч(СотрудникДанные) <> Тип("Структура") Тогда
			Возврат ОтветСОшибкой(400, "employee_required", "Блок employee обязателен");
		КонецЕсли;
		Если ТипЗнч(ОтпускДанные) <> Тип("Структура") Тогда
			Возврат ОтветСОшибкой(400, "vacation_required", "Блок vacation обязателен");
		КонецЕсли;

		ДатаНачала = ДатаISOОтпуск(ПолеJSON(ОтпускДанные, "startDate", ""));
		ДатаОкончания = ДатаISOОтпуск(ПолеJSON(ОтпускДанные, "endDate", ""));
		Если ДатаНачала = Неопределено Или ДатаОкончания = Неопределено Тогда
			Возврат ОтветСОшибкой(400, "invalid_period", "Некорректные даты отпуска");
		КонецЕсли;
		Если ДатаОкончания < ДатаНачала Тогда
			Возврат ОтветСОшибкой(400, "invalid_period", "Дата окончания отпуска меньше даты начала");
		КонецЕсли;

		КоличествоДней = Цел(ЧислоJSON(ПолеJSON(ОтпускДанные, "calendarDays", 0)));
		Если КоличествоДней <= 0 Тогда
			КоличествоДней = (НачалоДня(ДатаОкончания) - НачалоДня(ДатаНачала)) / 86400 + 1;
		КонецЕсли;

		Маркер = "[NNMC-BPM] " + КлючЗапроса;
		ЗапросДубля = Новый Запрос;
		ЗапросДубля.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Документ.Ссылка КАК Ссылка,
		|	Документ.Номер КАК Номер,
		|	Документ.Дата КАК Дата
		|ИЗ
		|	Документ.ОтпускаСотрудников КАК Документ
		|ГДЕ
		|	НЕ Документ.ПометкаУдаления
		|	И ВЫРАЗИТЬ(Документ.Комментарий КАК СТРОКА(200)) ПОДОБНО &Комментарий";
		ЗапросДубля.УстановитьПараметр("Комментарий", Маркер + "%");
		ВыборкаДубля = ЗапросДубля.Выполнить().Выбрать();
		Если ВыборкаДубля.Следующий() Тогда
			РезультатДубля = Новый Структура;
			РезультатДубля.Вставить("success", Истина);
			РезультатДубля.Вставить("duplicate", Истина);
			РезультатДубля.Вставить("documentId", UUIDСсылки(ВыборкаДубля.Ссылка));
			РезультатДубля.Вставить("number", СокрЛП(Строка(ВыборкаДубля.Номер)));
			РезультатДубля.Вставить("date", ВыборкаДубля.Дата);
			РезультатДубля.Вставить("posted", Ложь);
			РезультатДубля.Вставить("requestNumber", КлючЗапроса);
			Возврат JSONОтвет(200, РезультатДубля);
		КонецЕсли;

		КадровыеДанные = НайтиКадровыеДанныеОтпуск(СотрудникДанные);
		Сотрудник = КадровыеДанные.Сотрудник;
		ФизическоеЛицо = КадровыеДанные.ФизическоеЛицо;
		Если Не ЗначениеЗаполнено(Сотрудник) Тогда
			Возврат ОтветСОшибкой(422, "employee_not_found", "Сотрудник не найден в 1С");
		КонецЕсли;

		Организация = КадровыеДанные.Организация;
		Если Не ЗначениеЗаполнено(Организация) Тогда
			Организация = НайтиОрганизациюОтпуск(СотрудникДанные);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Организация) Тогда
			Возврат ОтветСОшибкой(422, "organization_not_found", "Организация не найдена в 1С");
		КонецЕсли;

		Подразделение = КадровыеДанные.Подразделение;
		Если Не ЗначениеЗаполнено(Подразделение) Тогда
			Подразделение = НайтиПодразделениеОтпуск(СотрудникДанные);
		КонецЕсли;
		ВидОтпуска = НайтиВидОтпускаОтпуск(ОтпускДанные);
		Если Не ЗначениеЗаполнено(ВидОтпуска) Тогда
			Возврат ОтветСОшибкой(422, "vacation_type_not_found", "Вид отпуска не найден в 1С");
		КонецЕсли;

		КомментарийДокумента = КомментарийОтпускаBPM(
			Маркер,
			Данные,
			СотрудникДанные,
			ОтпускДанные,
			РуководительДанные);

		НачатьТранзакцию();
		Попытка
			НовыйДокумент = Документы.ОтпускаСотрудников.СоздатьДокумент();

			Шапка = Новый Структура;
			Шапка.Вставить("Дата", ТекущаяДата());
			Шапка.Вставить("Организация", Организация);
			Шапка.Вставить("ПериодПринадлежности", НачалоМесяца(ДатаНачала));
			Шапка.Вставить("Комментарий", КомментарийДокумента);
			Шапка.Вставить("КраткийСоставДокумента", "BPM: " + КлючЗапроса);
			ЗаполнитьЗначенияСвойств(НовыйДокумент, Шапка);

			ИдентификаторСтроки = Новый УникальныйИдентификатор;

			СтрокаСотрудника = НовыйДокумент.Сотрудники.Добавить();
			ПоляСотрудника = Новый Структура;
			ПоляСотрудника.Вставить("Сотрудник", Сотрудник);
			ПоляСотрудника.Вставить("ФизическоеЛицо", ФизическоеЛицо);
			ПоляСотрудника.Вставить("ДатаНачала", ДатаНачала);
			ПоляСотрудника.Вставить("ДатаОкончания", ДатаОкончания);
			ПоляСотрудника.Вставить("ИдентификаторСтрокиСотрудника", ИдентификаторСтроки);
			ПоляСотрудника.Вставить("ПредоставитьМатериальнуюПомощьПриОтпуске", Ложь);
			ПоляСотрудника.Вставить("ПредоставитьЕдиновременнуюВыплатуКОтпуску", Ложь);
			ПоляСотрудника.Вставить("ОсвобождатьСтавку", Ложь);
			ПоляСотрудника.Вставить("Отпуск", Истина);
			ПоляСотрудника.Вставить("ОтпускБезОплаты", Ложь);
			ЗаполнитьЗначенияСвойств(СтрокаСотрудника, ПоляСотрудника);

			СтрокаОтпуска = НовыйДокумент.Отпуска.Добавить();
			ПоляОтпуска = Новый Структура;
			ПоляОтпуска.Вставить("УдалитьСотрудник", Сотрудник);
			ПоляОтпуска.Вставить("УдалитьФизическоеЛицо", ФизическоеЛицо);
			ПоляОтпуска.Вставить("ВидОтпуска", ВидОтпуска);
			ПоляОтпуска.Вставить("ДатаНачала", ДатаНачала);
			ПоляОтпуска.Вставить("ДатаОкончания", ДатаОкончания);
			ПоляОтпуска.Вставить("НачалоПериодаЗаКоторыйПредоставляетсяОтпуск", ДатаНачала);
			ПоляОтпуска.Вставить("КонецПериодаЗаКоторыйПредоставляетсяОтпуск", ДатаОкончания);
			ПоляОтпуска.Вставить("Основание", "Заявка BPM " + КлючЗапроса);
			ПоляОтпуска.Вставить("КоличествоДней", КоличествоДней);
			ПоляОтпуска.Вставить("КоличествоДнейКомпенсации", 0);
			ПоляОтпуска.Вставить("Оплата", Истина);
			ПоляОтпуска.Вставить("ИдентификаторСтрокиСотрудника", ИдентификаторСтроки);
			ЗаполнитьЗначенияСвойств(СтрокаОтпуска, ПоляОтпуска);

			НовыйДокумент.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;

		Результат = Новый Структура;
		Результат.Вставить("success", Истина);
		Результат.Вставить("duplicate", Ложь);
		Результат.Вставить("documentId", UUIDСсылки(НовыйДокумент.Ссылка));
		Результат.Вставить("number", СокрЛП(Строка(НовыйДокумент.Номер)));
		Результат.Вставить("date", НовыйДокумент.Дата);
		Результат.Вставить("posted", Ложь);
		Результат.Вставить("requestNumber", КлючЗапроса);
		Результат.Вставить("employee", СокрЛП(Строка(Сотрудник)));
		Результат.Вставить("organization", СокрЛП(Строка(Организация)));
		Результат.Вставить("vacationType", СокрЛП(Строка(ВидОтпуска)));
		Результат.Вставить("days", КоличествоДней);
		Возврат JSONОтвет(201, Результат);
	Исключение
		Возврат ОтветСОшибкой(500, "internal_error", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция ДатаISOОтпуск(Значение)
	СтрокаДата = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(СтрокаДата) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		ГодДаты = Число(Сред(СтрокаДата, 1, 4));
		МесяцДаты = Число(Сред(СтрокаДата, 6, 2));
		ДеньДаты = Число(Сред(СтрокаДата, 9, 2));
		Возврат Дата(ГодДаты, МесяцДаты, ДеньДаты);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция СсылкаПоUUIDОтпуск(МенеджерСправочника, UUIDСтрока)
	UUIDСтрока = СокрЛП(Строка(UUIDСтрока));
	Если ПустаяСтрока(UUIDСтрока) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Ссылка = МенеджерСправочника.ПолучитьСсылку(Новый УникальныйИдентификатор(UUIDСтрока));
		Если ЗначениеЗаполнено(Ссылка) Тогда
			Возврат Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

Функция НайтиКадровыеДанныеОтпуск(СотрудникДанные)
	Результат = Новый Структура;
	Результат.Вставить("Сотрудник", Неопределено);
	Результат.Вставить("ФизическоеЛицо", Неопределено);
	Результат.Вставить("Организация", Неопределено);
	Результат.Вставить("Подразделение", Неопределено);

	ФизическоеЛицо = НайтиФизическоеЛицоОтпуск(СотрудникДанные);
	Если ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Результат.ФизическоеЛицо = ФизическоеЛицо;
		Попытка
			ЗапросКадровыхДанных = Новый Запрос;
			ЗапросКадровыхДанных.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	КадровыеДанные.Сотрудник КАК Сотрудник,
			|	КадровыеДанные.ФизическоеЛицо КАК ФизическоеЛицо,
			|	КадровыеДанные.ТекущаяОрганизация КАК Организация,
			|	КадровыеДанные.ТекущееПодразделение КАК Подразделение
			|ИЗ
			|	РегистрСведений.ТекущиеКадровыеДанныеСотрудников.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК КадровыеДанные
			|ГДЕ
			|	НЕ КадровыеДанные.Сотрудник.ПометкаУдаления";
			ЗапросКадровыхДанных.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
			ЗапросКадровыхДанных.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
			ВыборкаКадровыхДанных = ЗапросКадровыхДанных.Выполнить().Выбрать();
			Если ВыборкаКадровыхДанных.Следующий() Тогда
				Результат.Сотрудник = ВыборкаКадровыхДанных.Сотрудник;
				Результат.ФизическоеЛицо = ВыборкаКадровыхДанных.ФизическоеЛицо;
				Результат.Организация = ВыборкаКадровыхДанных.Организация;
				Результат.Подразделение = ВыборкаКадровыхДанных.Подразделение;
				Возврат Результат;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Сотрудник = НайтиСотрудникаОтпуск(СотрудникДанные);
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		Результат.Сотрудник = Сотрудник;
		Если Не ЗначениеЗаполнено(Результат.ФизическоеЛицо) Тогда
			Попытка
				Результат.ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сотрудник, "ФизическоеЛицо");
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;
КонецФункции

Функция НайтиФизическоеЛицоОтпуск(СотрудникДанные)
	ФизическоеЛицо = СсылкаПоUUIDОтпуск(Справочники.ФизическиеЛица, ПолеJSON(СотрудникДанные, "physicalPersonId", ""));
	Если ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат ФизическоеЛицо;
	КонецЕсли;

	ИИН = СокрЛП(Строка(ПолеJSON(СотрудникДанные, "iin", "")));
	Если Не ПустаяСтрока(ИИН) Тогда
		Попытка
			ЗапросФизлица = Новый Запрос;
			ЗапросФизлица.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ФизическиеЛица.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.ФизическиеЛица КАК ФизическиеЛица
			|ГДЕ
			|	НЕ ФизическиеЛица.ПометкаУдаления
			|	И ФизическиеЛица.ИИН = &ИИН";
			ЗапросФизлица.УстановитьПараметр("ИИН", ИИН);
			ВыборкаФизлица = ЗапросФизлица.Выполнить().Выбрать();
			Если ВыборкаФизлица.Следующий() Тогда
				Возврат ВыборкаФизлица.Ссылка;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НайтиСотрудникаОтпуск(СотрудникДанные)
	Сотрудник = СсылкаПоUUIDОтпуск(Справочники.Сотрудники, ПолеJSON(СотрудникДанные, "employeeId", ""));
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат Сотрудник;
	КонецЕсли;

	ФИО = СокрЛП(Строка(ПолеJSON(СотрудникДанные, "fio", "")));
	Если ПустаяСтрока(ФИО) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросСотрудника = Новый Запрос;
	ЗапросСотрудника.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 2
	|	Сотрудник.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудник
	|ГДЕ
	|	НЕ Сотрудник.ПометкаУдаления
	|	И НЕ Сотрудник.ВАрхиве
	|	И Сотрудник.Наименование = &ФИО";
	ЗапросСотрудника.УстановитьПараметр("ФИО", ФИО);
	ТаблицаСотрудников = ЗапросСотрудника.Выполнить().Выгрузить();
	Если ТаблицаСотрудников.Количество() = 1 Тогда
		Возврат ТаблицаСотрудников[0].Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НайтиОрганизациюОтпуск(СотрудникДанные)
	Организация = СсылкаПоUUIDОтпуск(Справочники.Организации, ПолеJSON(СотрудникДанные, "organizationId", ""));
	Если ЗначениеЗаполнено(Организация) Тогда
		Возврат Организация;
	КонецЕсли;

	Наименование = СокрЛП(Строка(ПолеJSON(СотрудникДанные, "organization", "")));
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросОрганизации = Новый Запрос;
	ЗапросОрганизации.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Организация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организация
	|ГДЕ
	|	НЕ Организация.ПометкаУдаления
	|	И Организация.Наименование = &Наименование";
	ЗапросОрганизации.УстановитьПараметр("Наименование", Наименование);
	Выборка = ЗапросОрганизации.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НайтиПодразделениеОтпуск(СотрудникДанные)
	Подразделение = СсылкаПоUUIDОтпуск(
		Справочники.ПодразделенияОрганизаций,
		ПолеJSON(СотрудникДанные, "departmentId", ""));
	Если ЗначениеЗаполнено(Подразделение) Тогда
		Возврат Подразделение;
	КонецЕсли;

	Наименование = СокрЛП(Строка(ПолеJSON(СотрудникДанные, "department", "")));
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросПодразделения = Новый Запрос;
	ЗапросПодразделения.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Подразделение.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПодразделенияОрганизаций КАК Подразделение
	|ГДЕ
	|	НЕ Подразделение.ПометкаУдаления
	|	И Подразделение.Наименование = &Наименование";
	ЗапросПодразделения.УстановитьПараметр("Наименование", Наименование);
	Выборка = ЗапросПодразделения.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НайтиВидОтпускаОтпуск(ОтпускДанные)
	Идентификатор = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "typeId", "")));
	Если Не ПустаяСтрока(Идентификатор) Тогда
		Попытка
			ЗапросПоИдентификатору = Новый Запрос;
			ЗапросПоИдентификатору.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ВидыОтпусков.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.ВидыОтпусков КАК ВидыОтпусков
			|ГДЕ
			|	НЕ ВидыОтпусков.ПометкаУдаления
			|	И НЕ ВидыОтпусков.Недействителен
			|	И ВидыОтпусков.АУ_ИдентификаторSimbase = &Идентификатор";
			ЗапросПоИдентификатору.УстановитьПараметр("Идентификатор", Идентификатор);
			ВыборкаПоИдентификатору = ЗапросПоИдентификатору.Выполнить().Выбрать();
			Если ВыборкаПоИдентификатору.Следующий() Тогда
				Возврат ВыборкаПоИдентификатору.Ссылка;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Наименование = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "type", "")));
	ВидОтпуска = НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, Истина);
	Если ЗначениеЗаполнено(ВидОтпуска) Тогда
		Возврат ВидОтпуска;
	КонецЕсли;

	НижнееНаименование = НРег(Наименование);
	Варианты = Новый Массив;
	Если СтрНайти(НижнееНаименование, "ежегод") > 0 Или СтрНайти(НижнееНаименование, "оплач") > 0 Тогда
		Варианты.Добавить("Отпуск ежегодный");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "без сохран") > 0 Или СтрНайти(НижнееНаименование, "без оплат") > 0 Тогда
		Варианты.Добавить("отпуск без сохранения заработной платы");
		Варианты.Добавить("Отпуск без оплаты");
		Варианты.Добавить("Отпуск без сохранения оплаты");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "учеб") > 0 Тогда
		Варианты.Добавить("Дополнительный учебный отпуск (оплачиваемый)");
		Варианты.Добавить("Дополнительный учебный отпуск без оплаты");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "беремен") > 0 Или СтрНайти(НижнееНаименование, "род") > 0 Тогда
		Варианты.Добавить("отпуск по беременности и родам");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "уход") > 0 И СтрНайти(НижнееНаименование, "реб") > 0 Тогда
		Варианты.Добавить("Отпуск по уходу за ребенком");
	КонецЕсли;
	Если СтрНайти(НижнееНаименование, "скрининг") > 0 Тогда
		Варианты.Добавить("Отпуск для прохождения скрининговых исследований");
	КонецЕсли;

	Для каждого Вариант Из Варианты Цикл
		ВидОтпуска = НайтиВидОтпускаПоНаименованиюОтпуск(Вариант, Истина);
		Если ЗначениеЗаполнено(ВидОтпуска) Тогда
			Возврат ВидОтпуска;
		КонецЕсли;
	КонецЦикла;

	Возврат НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, Ложь);
КонецФункции

Функция НайтиВидОтпускаПоНаименованиюОтпуск(Наименование, ТочноеСовпадение)
	Наименование = СокрЛП(Строка(Наименование));
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросВидаОтпуска = Новый Запрос;
	Если ТочноеСовпадение Тогда
		УсловиеНаименования = "ВРЕГ(ВидыОтпусков.Наименование) = ВРЕГ(&Наименование)";
		ПараметрНаименования = Наименование;
	Иначе
		УсловиеНаименования = "ВРЕГ(ВидыОтпусков.Наименование) ПОДОБНО ВРЕГ(&Наименование)";
		ПараметрНаименования = "%" + Наименование + "%";
	КонецЕсли;
	ЗапросВидаОтпуска.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыОтпусков.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыОтпусков КАК ВидыОтпусков
	|ГДЕ
	|	НЕ ВидыОтпусков.ПометкаУдаления
	|	И НЕ ВидыОтпусков.Недействителен
	|	И " + УсловиеНаименования;
	ЗапросВидаОтпуска.УстановитьПараметр("Наименование", ПараметрНаименования);
	ВыборкаВидаОтпуска = ЗапросВидаОтпуска.Выполнить().Выбрать();
	Если ВыборкаВидаОтпуска.Следующий() Тогда
		Возврат ВыборкаВидаОтпуска.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция КомментарийОтпускаBPM(Маркер, Данные, СотрудникДанные, ОтпускДанные, РуководительДанные)
	Комментарий = Маркер;
	Комментарий = Комментарий + Символы.ПС + "Источник: " + СокрЛП(Строка(ПолеJSON(Данные, "source", "NNMC BPM")));
	Комментарий = Комментарий + Символы.ПС + "Сотрудник: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "fio", "")));
	Комментарий = Комментарий + Символы.ПС + "ИИН: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "iin", "")));
	Комментарий = Комментарий + Символы.ПС + "Табельный номер: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "personnelNumber", "")));
	Комментарий = Комментарий + Символы.ПС + "Подразделение: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "department", "")));
	Комментарий = Комментарий + Символы.ПС + "Должность: " + СокрЛП(Строка(ПолеJSON(СотрудникДанные, "position", "")));
	Комментарий = Комментарий + Символы.ПС + "Вид отпуска: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "type", "")));
	Комментарий = Комментарий + Символы.ПС + "Период: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "startDate", "")))
		+ " - " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "endDate", "")));
	Комментарий = Комментарий + Символы.ПС + "Дней: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "calendarDays", "")));
	Комментарий = Комментарий + Символы.ПС + "Замещающий: " + СокрЛП(Строка(ПолеJSON(ОтпускДанные, "replacementEmployeeName", "")));
	Если ТипЗнч(РуководительДанные) = Тип("Структура") Тогда
		Комментарий = Комментарий + Символы.ПС + "Руководитель: " + СокрЛП(Строка(ПолеJSON(РуководительДанные, "name", "")));
	КонецЕсли;
	КомментарийПользователя = СокрЛП(Строка(ПолеJSON(ОтпускДанные, "comment", "")));
	Если Не ПустаяСтрока(КомментарийПользователя) Тогда
		Комментарий = Комментарий + Символы.ПС + "Комментарий: " + КомментарийПользователя;
	КонецЕсли;
	Возврат Комментарий;
КонецФункции
