{
  "kind": "collectionType",
  "collectionName": "protocols",
  "info": {
    "singularName": "protocol",
    "pluralName": "protocols",
    "displayName": "Protocol",
    "description": "Протоколы совещаний"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "theme": {
      "type": "string",
      "required": true
    },
    "meetingDate": {
      "type": "date",
      "required": true
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "creatorDepartment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department"
    },
    "attendees": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "responsibles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "tasks": {
      "type": "component",
      "repeatable": true,
      "component": "protocol.task"
    },
    "conclusion": {
      "type": "text"
    },
    "nextMeetingDate": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "published"],
      "default": "draft"
    },
    "version": {
      "type": "integer",
      "default": 1
    },
    "pdfFiles": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["files"]
    },
    "history": {
      "type": "json"
    }
  }
}
