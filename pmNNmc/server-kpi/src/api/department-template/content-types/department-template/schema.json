{
  "kind": "collectionType",
  "collectionName": "department_templates",
  "info": {
    "singularName": "department-template",
    "pluralName": "department-templates",
    "displayName": "DepartmentTemplate",
    "description": "Per-department protocol template with commission members"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "departmentKey": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "departmentName": {
      "type": "string",
      "required": true
    },
    "protocolNumber": {
      "type": "string"
    },
    "meetingTitle": {
      "type": "string"
    },
    "place": {
      "type": "string"
    },
    "agendaText": {
      "type": "text"
    },
    "footerText": {
      "type": "text"
    },
    "commissionMembers": {
      "type": "component",
      "repeatable": true,
      "component": "report.commission-member"
    },
    "secretaryName": {
      "type": "string"
    },
    "coordinatorRole": {
      "type": "string"
    },
    "meetingDateOverrides": {
      "type": "component",
      "repeatable": true,
      "component": "report.meeting-date"
    }
  }
}
